  "keywords": [
    "analytics",
    "dashboard",
    "manufacturing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
